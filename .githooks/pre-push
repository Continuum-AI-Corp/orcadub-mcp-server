#!/usr/bin/env bash
set -euo pipefail

# Only process .go files that differ from the remote
STAGED_GO_FILES=$(git diff --name-only --diff-filter=ACM HEAD | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  exit 0
fi

# Dependency check
check_tool() {
  if ! command -v "$1" &>/dev/null; then
    echo "[pre-push] '$1' not installed. Run: $2"
    exit 1
  fi
}

check_tool goimports "go install golang.org/x/tools/cmd/goimports@latest"
check_tool golangci-lint "https://golangci-lint.run/usage/install/"

ROOT=$(git rev-parse --show-toplevel)

# Format
echo "[pre-push] Formatting Go files..."
for FILE in $STAGED_GO_FILES; do
  ABS="$ROOT/$FILE"
  [ -f "$ABS" ] || continue
  goimports -w "$ABS"
  gofmt -w "$ABS"
done

# Abort push if formatting changed any file (force a commit first)
if ! git diff --quiet; then
  echo ""
  echo "[pre-push] Formatting changed the following files — please commit them before pushing:"
  git diff --name-only
  exit 1
fi

# Lint
echo "[pre-push] Running golangci-lint..."
(
  cd "$ROOT"
  golangci-lint run ./...
)

echo "[pre-push] All checks passed ✓"
