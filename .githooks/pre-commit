#!/usr/bin/env bash
set -euo pipefail

# Only process staged .go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  exit 0
fi

# ── Dependency check ──────────────────────────────────────────────────────────
check_tool() {
  if ! command -v "$1" &>/dev/null; then
    echo "[pre-commit] '$1' is not installed. Run: $2"
    exit 1
  fi
}

check_tool goimports "go install golang.org/x/tools/cmd/goimports@latest"
check_tool golangci-lint "https://golangci-lint.run/usage/install/"

# ── Format ────────────────────────────────────────────────────────────────────
echo "[pre-commit] formatting Go files..."

# Resolve the repository root (where go.mod lives)
ROOT=$(git rev-parse --show-toplevel)

for FILE in $STAGED_GO_FILES; do
  ABS="$ROOT/$FILE"
  [ -f "$ABS" ] || continue
  goimports -w "$ABS"
  gofmt -w "$ABS"
  git add "$FILE"
done

# ── Lint (with auto-fix) ──────────────────────────────────────────────────────
echo "[pre-commit] running golangci-lint --fix..."

# Run from the repository root that contains go.mod
(
  cd "$ROOT"
  golangci-lint run --fix ./... 2>&1
)

# Re-stage files touched by lint auto-fixes
for FILE in $STAGED_GO_FILES; do
  git add "$FILE" 2>/dev/null || true
done

echo "[pre-commit] checks passed"
